{
  "name": "@rootz-global/rootz-platform",
  "version": "1.0.0",
  "description": "Rootz Platform - Email Data Wallet system for signing emails with data wallets",
  "main": "index.mjs",
  "type": "module",
  "files": [
    "src/**/*",
    "contracts/**/*",
    "docs/**/*",
    "config-templates/**/*",
    "index.mjs",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rootz-global/sks-rootz-platform.git"
  },
  "author": "Rootz Global",
  "license": "MIT",
  "keywords": [
    "blockchain",
    "email-wallet",
    "email-processing",
    "ipfs",
    "secrets-management",
    "ai-data-wallet",
    "epistery",
    "microservices",
    "typescript",
    "microsoft-graph",
    "polygon",
    "ethereum",
    "installer",
    "cli"
  ],
  "scripts": {
    "build": "echo 'No build step needed for ES modules'",
    "start": "node index.mjs",
    "dev": "node index.mjs",
    "dev:watch": "nodemon index.mjs",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "echo 'Linting disabled for ES module version'",
    "lint:fix": "echo 'Linting disabled for ES module version'",
    "hardhat:compile": "npx hardhat compile",
    "hardhat:test": "npx hardhat test",
    "hardhat:node": "npx hardhat node",
    "contract:deploy": "npx hardhat run contracts/deployment/scripts/deploy-enhanced-email-wallet.js --network amoy",
    "contract:deploy:local": "npx hardhat run contracts/deployment/scripts/deploy-enhanced-email-wallet.js --network localhost",
    "contract:verify": "npx hardhat verify --network amoy"
  },
  "dependencies": {
    "@azure/identity": "^4.0.1",
    "@azure/msal-node": "^2.6.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "bcryptjs": "2.4.3",
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "cookie-parser": "1.4.7",
    "cors": "2.8.5",
    "dotenv": "16.3.1",
    "epistery": "file:../epistery",
    "ethers": "5.7.2",
    "express": "4.18.2",
    "express-rate-limit": "6.8.0",
    "fs-extra": "^11.1.1",
    "helmet": "7.0.0",
    "ini": "5.0.0",
    "inquirer": "^9.2.12",
    "joi": "17.9.2",
    "jsonwebtoken": "9.0.2",
    "mailparser": "^3.6.5",
    "mysql2": "^3.6.0",
    "node-fetch": "^2.7.0",
    "ora": "^7.0.1",
    "pg": "^8.11.0",
    "redis": "4.6.0",
    "winston": "3.10.0"
  },
  "devDependencies": {
    "@nomiclabs/hardhat-ethers": "^2.2.3",
    "@nomiclabs/hardhat-waffle": "^2.0.6",
    "@openzeppelin/contracts": "^4.9.3",
    "chai": "^4.3.7",
    "ethereum-waffle": "^4.0.10",
    "hardhat": "^2.17.0",
    "hardhat-gas-reporter": "^1.0.9",
    "nodemon": "^3.0.0",
    "prettier": "^3.0.0",
    "solidity-coverage": "^0.8.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
